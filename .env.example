# Neon Postgres connection string (same value as sift-api).
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# Voyage AI key — used to embed search queries for vector similarity
# over the articles index. Same key as sift-api.
VOYAGE_API_KEY=

# Anthropic key — used by the `compare_outlets` tool for claim extraction
# across articles in Sift's index. One Claude Haiku call per comparison.
ANTHROPIC_API_KEY=
